# ── Qwen Cloud (DashScope) — optional, live mode only ──────────
# Everything runs offline with zero keys by default (FakeQwen transport).
# Set this only to exercise --live: qwen3-vl-plus (extraction) + qwen3.7-max
# (adjudication) via the DashScope OpenAI-compatible endpoint.
# Get from: https://dashscope.console.aliyun.com/apiKey
DASHSCOPE_API_KEY=sk-your-dashscope-key-here

# ── Optional ─────────────────────────────────────────────────
# Override the data root (seeded month, ledger, evidence store).
# Defaults to the repo root when unset.
# INNKEEPER_ROOT=/path/to/data/root
